{
  "name": "mlm-hosting-saas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @mlm-hosting-saas/web",
    "dev:api": "npm run dev --workspace @mlm-hosting-saas/api",
    "dev:jobs": "npm run dev --workspace @mlm-hosting-saas/jobs",
    "start:api": "npm run start --workspace @mlm-hosting-saas/api",
    "db:migrate": "npm run migrate --workspace @mlm-hosting-saas/database",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
